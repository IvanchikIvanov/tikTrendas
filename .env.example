# Runtime environment
T2V_ENV=local

# Database
T2V_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trend2video

# Trend and keyword sources
T2V_TREND_SOURCE=static
T2V_STATIC_TRENDS_PATH=data/static_trends.json
T2V_DEFAULT_KEYWORD_SOURCE_TYPE=static
T2V_STATIC_KEYWORD_INSIGHTS_PATH=data/static_keyword_insights.json
T2V_DEFAULT_RELATED_VIDEOS_PER_KEYWORD=3
T2V_DEFAULT_TOP_KEYWORDS_LIMIT=10

# TikTok Creative Center / live HTTP keyword source
T2V_TIKTOK_CREATIVE_CENTER_URL=https://www.tiktok.com/business/creativecenter/inspiration/popular/hashtag
T2V_TIKTOK_REGION=US
T2V_TIKTOK_COOKIE_HEADER=sessionid_ads=example_session_cookie; msToken=example_ms_token
T2V_TIKTOK_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36
T2V_TIKTOK_REFERER=https://ads.tiktok.com/business/creativecenter/keyword-insights/pc/en
T2V_TIKTOK_ACCEPT_LANGUAGE=en-US,en;q=0.9
T2V_TIKTOK_EXTRA_HEADERS_JSON={"x-csrftoken":"example_csrf_token"}
T2V_TIKTOK_STORAGE_STATE_PATH=
T2V_MEDIA_STORAGE_BASE_PATH=data/media

# Brand context override.
T2V_BRAND_CONTEXT={"product_name":"LeadFlow","product_type":"sales automation platform","audience":["small business owners","sales teams","marketers"],"pain_points":["slow lead response","manual qualification","lost inbound requests"],"tone":"direct","forbidden_topics":["medical claims","fake guarantees"],"cta_style":"short_direct","niche_tags":["sales","automation","leadgen"]}
